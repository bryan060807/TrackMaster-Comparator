# TrackMaster-Comparator has no required environment variables.
#
# Optional static runtime settings used by server/static-server.mjs:
# - Keep HOST=127.0.0.1 for local-only Windows use.
# - Use HOST=0.0.0.0 or the Windows LAN IP only when another host, such as
#   the Fedora reverse proxy, must reach this Windows runtime.
HOST=127.0.0.1
PORT=8081
